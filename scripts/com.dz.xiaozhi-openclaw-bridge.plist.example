<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dz.xiaozhi-openclaw-bridge</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/PATH/TO/xiaozhi-openclaw-bridge/src/mcp_pipe.py</string>
        <string>/PATH/TO/xiaozhi-openclaw-bridge/src/openclaw_tool.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/PATH/TO/xiaozhi-openclaw-bridge</string>
    <key>StandardOutPath</key>
    <string>/tmp/xiaozhi-openclaw-bridge/bridge.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/xiaozhi-openclaw-bridge/bridge.err</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
</dict>
</plist>
